{
  "name": "bygone",
  "publisher": "davidmashburn",
  "displayName": "Bygone",
  "description": "See how change happened. Visual diff and file history for VS Code.",
  "version": "0.4.2",
  "author": "David Mashburn",
  "license": "MIT",
  "private": false,
  "preview": true,
  "icon": "media/icon.png",
  "bin": {
    "bygone": "./bin/bygone.js"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/davidmashburn/bygone.git"
  },
  "bugs": {
    "url": "https://github.com/davidmashburn/bygone/issues"
  },
  "homepage": "https://github.com/davidmashburn/bygone",
  "keywords": [
    "diff",
    "git",
    "compare",
    "history",
    "visual"
  ],
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "onUri",
    "onCommand:bygone.compareFiles",
    "onCommand:bygone.compareDirectories",
    "onCommand:bygone.compareThreeDirectories",
    "onCommand:bygone.compareThreeFiles",
    "onCommand:bygone.compareWithSelected",
    "onCommand:bygone.compareTestFiles",
    "onCommand:bygone.compareFileHistory",
    "onCommand:bygone.compareActiveFileHistory",
    "onView:bygone.diffView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bygone.compareFiles",
        "title": "Compare Files",
        "category": "Bygone"
      },
      {
        "command": "bygone.compareDirectories",
        "title": "Compare Directories",
        "category": "Bygone"
      },
      {
        "command": "bygone.compareThreeDirectories",
        "title": "Compare Three Directories (Prototype)",
        "category": "Bygone"
      },
      {
        "command": "bygone.compareThreeFiles",
        "title": "Compare Three Files (Prototype)",
        "category": "Bygone"
      },
      {
        "command": "bygone.compareWithSelected",
        "title": "Compare with Selected",
        "category": "Bygone"
      },
      {
        "command": "bygone.compareTestFiles",
        "title": "Compare Test Files",
        "category": "Bygone"
      },
      {
        "command": "bygone.compareFileHistory",
        "title": "Compare File History",
        "category": "Bygone"
      },
      {
        "command": "bygone.compareActiveFileHistory",
        "title": "Compare Active File History",
        "category": "Bygone"
      },
      {
        "command": "bygone.openStandaloneDownloads",
        "title": "Open Standalone App Downloads",
        "category": "Bygone"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "bygone.compareWithSelected",
          "group": "compare"
        },
        {
          "command": "bygone.compareDirectories",
          "group": "compare"
        },
        {
          "command": "bygone.compareFileHistory",
          "group": "compare"
        },
        {
          "command": "bygone.compareActiveFileHistory",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "bygone.compareWithSelected",
          "group": "compare"
        },
        {
          "command": "bygone.compareFileHistory",
          "group": "compare"
        },
        {
          "command": "bygone.compareActiveFileHistory",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bygonediff",
          "title": "Bygone",
          "icon": "$(compare-changes)"
        }
      ]
    },
    "views": {
      "bygonediff": [
        {
          "id": "bygone.diffView",
          "name": "Diff View",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "rm -rf out *.vsix",
    "typecheck": "tsc -p ./ --noEmit",
    "compile": "npm run typecheck && node ./scripts/build.mjs",
    "icons:generate": "node ./scripts/generate-icons.mjs",
    "package:vsix": "vsce package",
    "standalone:start": "npm run compile && electron ./out/standalone-main.js",
    "standalone:smoke": "npm run compile && electron ./out/standalone-main.js --smoke-test",
    "web:start": "npm run compile && node ./scripts/web-server.mjs",
    "package:desktop": "npm run package:desktop:mac",
    "package:desktop:mac": "npm run compile && electron-builder --mac dmg --publish never",
    "package:desktop:mac:zip": "npm run compile && electron-builder --mac zip --publish never",
    "package:desktop:linux": "npm run compile && electron-builder --linux AppImage --publish never",
    "package:desktop:win": "npm run compile && electron-builder --win --publish never",
    "package:desktop:all": "npm run compile && electron-builder --mac --win --linux AppImage --publish never",
    "package:npm": "npm run compile && node ./scripts/package-npm.mjs",
    "package:npm:dry-run": "node ./scripts/pack-npm-dry-run.mjs",
    "perf:bench": "npm run compile && node ./scripts/perf-benchmarks.mjs",
    "perf:check": "npm run compile && node ./scripts/perf-check.mjs",
    "release:check": "npm test && npm run package:vsix && npm run package:npm && npm run package:npm:dry-run",
    "release:build": "node ./scripts/release.mjs",
    "release:publish": "node ./scripts/release.mjs --publish",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node ./test/runTests.js"
  },
  "build": {
    "appId": "com.davidmashburn.bygone",
    "productName": "Bygone",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "media/webview.css",
      "media/webview.js",
      "media/editor.worker.js",
      "media/icon.png",
      "standalone/**",
      "package.json",
      "README.md",
      "LICENSE.txt",
      "CHANGELOG.md"
    ],
    "extraMetadata": {
      "main": "out/standalone-main.js"
    },
    "asarUnpack": [
      "media/editor.worker.js"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "standalone/assets/Bygone.icns"
    },
    "dmg": {
      "writeUpdateInfo": true
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "standalone/assets/Bygone.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "media/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "davidmashburn",
        "repo": "bygone"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.7.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "diff": "^5.1.0",
    "electron-updater": "^6.8.3",
    "monaco-editor": "^0.55.1"
  }
}
